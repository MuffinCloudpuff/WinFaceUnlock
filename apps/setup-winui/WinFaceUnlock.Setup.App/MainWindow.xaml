<Window
    x:Class="WinFaceUnlock.Setup.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="WinFaceUnlock Setup">

    <Grid Background="#F6F7F9" MinWidth="760" MinHeight="520">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Background="#FFFFFF" Padding="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding ProductName}" FontSize="24" FontWeight="SemiBold" Foreground="#202124" />
                    <TextBlock Text="{Binding CurrentStepName}" FontSize="13" Foreground="#5F6368" />
                </StackPanel>

                <ListView
                    Grid.Row="1"
                    Margin="0,28,0,0"
                    ItemsSource="{Binding Steps}"
                    SelectionMode="None"
                    IsItemClickEnabled="False"
                    IsHitTestVisible="False"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="MinHeight" Value="40" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,2" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnSpacing="10" MinHeight="36">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Text="{Binding Glyph}"
                                    FontFamily="Segoe MDL2 Assets"
                                    Width="24"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="#2563EB" />
                                <TextBlock
                                    Grid.Column="1"
                                    Text="{Binding Title}"
                                    VerticalAlignment="Center"
                                    TextTrimming="CharacterEllipsis"
                                    Foreground="#202124" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Button
                    Grid.Row="2"
                    HorizontalAlignment="Left"
                    Content="{Binding LanguageToggleText}"
                    Command="{Binding ToggleLanguageCommand}" />
            </Grid>

            <Grid Grid.Column="1" Padding="34">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <StackPanel Visibility="{Binding WelcomeVisibility}" Spacing="18" MaxWidth="620">
                        <TextBlock Text="{Binding WelcomeTitle}" FontSize="34" FontWeight="SemiBold" Foreground="#202124" />
                        <TextBlock Text="{Binding WelcomeSubtitle}" FontSize="18" Foreground="#374151" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding WelcomeBody}" FontSize="14" Foreground="#4B5563" TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Visibility="{Binding DisclaimerVisibility}" Spacing="18" MaxWidth="660">
                        <TextBlock Text="{Binding DisclaimerTitle}" FontSize="28" FontWeight="SemiBold" Foreground="#202124" />
                        <TextBlock Text="{Binding DisclaimerBody}" FontSize="14" Foreground="#374151" TextWrapping="Wrap" />
                        <CheckBox
                            Content="{Binding AcceptDisclaimerText}"
                            IsChecked="{Binding DisclaimerAccepted, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Visibility="{Binding InstallLocationVisibility}" Spacing="16" MaxWidth="660">
                        <TextBlock Text="{Binding InstallLocationTitle}" FontSize="28" FontWeight="SemiBold" Foreground="#202124" />
                        <TextBlock Text="{Binding InstallLocationBody}" FontSize="14" Foreground="#4B5563" TextWrapping="Wrap" />
                        <Grid ColumnSpacing="10" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding InstallDirectoryLabel}" VerticalAlignment="Center" Foreground="#374151" />
                            <TextBox Grid.Column="1" Text="{Binding InstallDir, Mode=TwoWay}" PlaceholderText="{Binding InstallDirPlaceholder}" />
                            <Button Grid.Column="2" Content="{Binding BrowseButtonText}" Command="{Binding BrowseInstallDirCommand}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Visibility="{Binding InstallingVisibility}" Spacing="18" MaxWidth="660">
                        <TextBlock Text="{Binding InstallingTitle}" FontSize="28" FontWeight="SemiBold" Foreground="#202124" />
                        <TextBlock Text="{Binding InstallingBody}" FontSize="14" Foreground="#4B5563" TextWrapping="Wrap" />
                        <ProgressBar
                            Height="8"
                            Minimum="0"
                            Maximum="100"
                            Value="{Binding InstallProgress}"
                            IsIndeterminate="{Binding InstallProgressIsIndeterminate}" />
                        <TextBlock Text="{Binding StatusMessage}" FontSize="13" Foreground="#374151" TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Visibility="{Binding CompleteVisibility}" Spacing="18" MaxWidth="660">
                        <TextBlock Text="{Binding CompleteTitle}" FontSize="28" FontWeight="SemiBold" Foreground="#202124" />
                        <TextBlock Text="{Binding CompleteBody}" FontSize="14" Foreground="#4B5563" TextWrapping="Wrap" />
                        <Border
                            Visibility="{Binding ErrorVisibility}"
                            Background="#FEF2F2"
                            BorderBrush="#DC2626"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding ErrorTitle}" FontSize="14" FontWeight="SemiBold" Foreground="#991B1B" />
                                <TextBlock Text="{Binding ErrorMessage}" FontSize="13" Foreground="#7F1D1D" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding ErrorDetails}" FontSize="12" Foreground="#7F1D1D" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <TextBlock Text="{Binding StatusMessage}" FontSize="13" Foreground="#374151" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>

        <Grid Grid.Row="1" Background="#FFFFFF" BorderBrush="#DADCE0" BorderThickness="0,1,0,0" Padding="18">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                <Button
                    Content="{Binding BackButtonText}"
                    Command="{Binding BackCommand}"
                    Visibility="{Binding WizardNavigationVisibility}" />
                <Button
                    Content="{Binding PrimaryActionText}"
                    Command="{Binding NextCommand}"
                    Visibility="{Binding WizardNavigationVisibility}" />
                <Button
                    Content="{Binding FinishButtonText}"
                    Command="{Binding FinishCommand}"
                    Visibility="{Binding FinishVisibility}" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
