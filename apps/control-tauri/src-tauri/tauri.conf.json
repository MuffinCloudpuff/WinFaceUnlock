{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WinFaceUnlock",
  "version": "0.1.0",
  "identifier": "com.winfaceunlock.control",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WinFaceUnlock",
        "width": 800,
        "height": 600,
        "minWidth": 560,
        "minHeight": 420,
        "resizable": true,
        "maximizable": true,
        "fullscreen": false,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}
